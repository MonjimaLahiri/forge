# Copy to .env.local and fill in to enable real AI text generation.
# Powers the Text Generator widget — without it, it falls back to mock output.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# The Image Generator widget needs no key — it calls Pollinations.ai's free,
# keyless image API directly and falls back to mock output if that's unreachable.
